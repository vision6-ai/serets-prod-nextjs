{
  "kind": "collectionType",
  "collectionName": "actors",
  "info": {
    "singularName": "actor",
    "pluralName": "actors",
    "displayName": "Actor",
    "description": "Collection of Israeli actors"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "hebrew_name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "biography": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "birth_date": {
      "type": "date"
    },
    "birth_place": {
      "type": "string"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "movies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::movie.movie",
      "mappedBy": "actors"
    },
    "awards": {
      "type": "component",
      "component": "achievements.award",
      "repeatable": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "required": false
    }
  }
}