{
  "collectionName": "components_media_videos",
  "info": {
    "displayName": "Video",
    "description": "Video content for movies"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "trailer",
        "teaser",
        "clip",
        "behind_the_scenes",
        "interview"
      ],
      "default": "trailer",
      "required": true
    },
    "language": {
      "type": "string"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}